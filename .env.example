NODE_ENV=development
API_PORT=3000
DATABASE_URL=postgresql://logmind:logmind@localhost:5432/logmind?schema=public
MONGODB_URL=mongodb://localhost:27017/logmind
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN_SECONDS=86400
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=15000
AI_PROVIDER_MODE=mock
AI_PROVIDER_FORCE_FAIL=false
CORS_ORIGIN=http://localhost:3001
LOGMIND_API_URL=http://localhost:3000
NEXT_PUBLIC_LOGMIND_API_URL=http://localhost:3000
NEXT_PUBLIC_LOGMIND_CLIENT_KEY=
ENABLE_SWAGGER=true
REQUEST_BODY_LIMIT=1mb
AUTH_RATE_LIMIT_PER_MINUTE=20
INGEST_RATE_LIMIT_PER_MINUTE=300
TRUST_PROXY_HOPS=0
LOGMIND_API_KEY=lm_server_replace_me
LOGMIND_INGEST_ENDPOINT=http://localhost:3000/logs/ingest
LOGMIND_AGENT_CONTAINER_ID=
LOGMIND_AGENT_RETRY_ATTEMPTS=3
LOGMIND_AGENT_RETRY_DELAY_MS=1000
