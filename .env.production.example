SITE_ADDRESS=:80
PUBLIC_API_URL=https://logmind.example.com/backend
CADDY_HOST_PORT=18080

POSTGRES_USER=logmind
POSTGRES_PASSWORD=replace_with_hex_secret
POSTGRES_DB=logmind
MONGO_ROOT_USERNAME=logmind
MONGO_ROOT_PASSWORD=replace_with_hex_secret
REDIS_PASSWORD=replace_with_hex_secret

JWT_SECRET=replace_with_at_least_32_random_bytes
JWT_EXPIRES_IN_SECONDS=86400
CORS_ORIGIN=https://logmind.example.com
LOG_LEVEL=info
ENABLE_SWAGGER=false
REQUEST_BODY_LIMIT=1mb
AUTH_RATE_LIMIT_PER_MINUTE=20
INGEST_RATE_LIMIT_PER_MINUTE=300
TRUST_PROXY_HOPS=1

AI_PROVIDER_MODE=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=15000

NEXT_PUBLIC_LOGMIND_CLIENT_KEY=
LOGMIND_API_KEY=
LOGMIND_AGENT_RETRY_ATTEMPTS=3
LOGMIND_AGENT_RETRY_DELAY_MS=1000
