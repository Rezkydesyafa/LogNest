generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApiKeyType {
  SERVER
  CLIENT
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  projects     Project[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  apiKeys     ApiKey[]
  services    Service[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerId, name])
  @@index([ownerId])
}

model ApiKey {
  id         String     @id @default(cuid())
  name       String
  type       ApiKeyType
  prefix     String
  keyHash    String     @unique
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime   @default(now())

  @@index([projectId])
  @@index([type])
}

model Service {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  environment String
  sourceTypes String[] @default([])
  metadata    Json?
  lastSeenAt  DateTime @default(now())
  logCount    Int      @default(0)
  errorCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, name, environment])
  @@index([projectId])
  @@index([name])
}
